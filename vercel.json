{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/lookout",
      "destination": "https://lookout-rho.vercel.app/lookout"
    },
    {
      "source": "/lookout/",
      "destination": "https://lookout-rho.vercel.app/lookout"
    },
    {
      "source": "/lookout/:path+",
      "destination": "https://lookout-rho.vercel.app/lookout/:path+"
    },
    {
      "source": "/lookout/:path+/",
      "destination": "https://lookout-rho.vercel.app/lookout/:path+"
    },
    {
      "source": "/fieldnotes",
      "destination": "https://fieldnotes-gray.vercel.app/fieldnotes"
    },
    {
      "source": "/fieldnotes/",
      "destination": "https://fieldnotes-gray.vercel.app/fieldnotes"
    },
    {
      "source": "/fieldnotes/:path+",
      "destination": "https://fieldnotes-gray.vercel.app/fieldnotes/:path+"
    },
    {
      "source": "/fieldnotes/:path+/",
      "destination": "https://fieldnotes-gray.vercel.app/fieldnotes/:path+"
    },
    {
      "source": "/library",
      "destination": "https://behavior-design-library.vercel.app/library"
    },
    {
      "source": "/library/",
      "destination": "https://behavior-design-library.vercel.app/library"
    },
    {
      "source": "/library/:path+",
      "destination": "https://behavior-design-library.vercel.app/library/:path+"
    },
    {
      "source": "/library/:path+/",
      "destination": "https://behavior-design-library.vercel.app/library/:path+"
    },
    {
      "source": "/api/unlock",
      "destination": "https://behavior-design-library.vercel.app/api/unlock"
    }
  ]
}
